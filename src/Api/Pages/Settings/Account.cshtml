@page "/settings/account"
@model Api.Pages.Settings.AccountModel
@{
    ViewData["Title"] = "Аккаунт";
    ViewData["ActivePage"] = "account";
}

<div class="card">
    <div class="card-header">
        <h1>Смена пароля</h1>
        <p>Обновите пароль администратора коннектора</p>
    </div>

    @if (Model.MustChange)
    {
        <div class="alert alert-warning">
            Для продолжения необходимо сменить пароль.
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-error">@Model.ErrorMessage</div>
    }

    <form method="post">
        <input type="hidden" asp-for="MustChange"/>

        <div class="form-grid">
            <div class="form-group">
                <label for="newPassword">Новый пароль</label>
                <div class="input-wrap">
                    <input type="password"
                           id="newPassword"
                           asp-for="NewPassword"
                           class="has-toggle"
                           placeholder="Минимум 8 символов"/>
                    <button type="button" class="toggle-password" onclick="togglePwd('newPassword')" tabindex="-1" aria-label="Показать пароль">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>

            <div class="form-group">
                <label for="confirmPassword">Подтверждение пароля</label>
                <div class="input-wrap">
                    <input type="password"
                           id="confirmPassword"
                           asp-for="ConfirmPassword"
                           class="has-toggle"
                           placeholder="Повторите пароль"/>
                    <button type="button" class="toggle-password" onclick="togglePwd('confirmPassword')" tabindex="-1" aria-label="Показать пароль">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Сохранить</button>
        </div>
    </form>
</div>

<script>
    function togglePwd(id) {
        const input = document.getElementById(id);
        input.type = input.type === 'password' ? 'text' : 'password';
    }
</script>
