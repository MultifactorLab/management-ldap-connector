@page "/settings/sync"
@model Api.Pages.Settings.SyncModel
@{
    ViewData["Title"] = "Синхронизация";
    ViewData["ActivePage"] = "sync";
}

<div class="card">
    <div class="card-header">
        <h1>Настройки синхронизации</h1>
        <p>Параметры подключения к MGM API и расписание синхронизации</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-error">@Model.ErrorMessage</div>
    }

    <form method="post" id="sync-form">
        <div class="form-grid">

            <div class="form-group">
                <label>Интервал синхронизации (минуты)</label>
                <input type="number" asp-for="IntervalMinutes" placeholder="60" min="1"/>
                <span class="field-hint">Минимум 1 минута</span>
                <span asp-validation-for="IntervalMinutes" class="field-error"></span>
            </div>

            <div class="form-group form-group-full">
                <label>URL MGM API</label>
                <input type="url" asp-for="ApiUrl" placeholder="https://mgm.company.local"/>
                <span asp-validation-for="ApiUrl" class="field-error"></span>
            </div>

            <div class="form-group">
                <label>API Key</label>
                <input type="text" asp-for="ApiKey" placeholder="Ключ авторизации"/>
                <span asp-validation-for="ApiKey" class="field-error"></span>
            </div>

            <div class="form-group">
                <label>API Secret</label>
                <div class="input-wrap">
                    <input type="text"
                           id="ApiSecret"
                           name="ApiSecret"
                           class="has-toggle"
                           autocomplete="off"
                           spellcheck="false"
                           placeholder="Секрет авторизации"
                           value="@Model.ApiSecret"/>
                    <button type="button" class="toggle-password"
                            onclick="toggleMask()" tabindex="-1">
                        <svg id="eye-open" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                        <svg id="eye-closed" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
                            <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/>
                            <path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/>
                            <line x1="1" y1="1" x2="23" y2="23"/>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="ApiSecret" class="field-error"></span>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Сохранить</button>
        </div>
    </form>
</div>

<script>
    const pwdInput = document.getElementById('ApiSecret');
    let realValue = pwdInput.value;
    let masked = true;

    if (realValue.length > 0) renderMask();

    function renderMask() {
        const sel = pwdInput.selectionStart;
        pwdInput.value = '•'.repeat(realValue.length);
        try { pwdInput.setSelectionRange(sel, sel); } catch {}
    }

    pwdInput.addEventListener('beforeinput', function (e) {
        if (!masked) return;
        e.preventDefault();

        const start = this.selectionStart;
        const end = this.selectionEnd;

        if (e.inputType === 'insertText' && e.data) {
            realValue = realValue.slice(0, start) + e.data + realValue.slice(end);
            renderMask();
            const pos = start + e.data.length;
            this.setSelectionRange(pos, pos);

        } else if (e.inputType === 'deleteContentBackward') {
            if (start === end && start > 0) {
                realValue = realValue.slice(0, start - 1) + realValue.slice(start);
                renderMask();
                this.setSelectionRange(start - 1, start - 1);
            } else if (start !== end) {
                realValue = realValue.slice(0, start) + realValue.slice(end);
                renderMask();
                this.setSelectionRange(start, start);
            }

        } else if (e.inputType === 'deleteContentForward') {
            if (start === end && start < realValue.length) {
                realValue = realValue.slice(0, start) + realValue.slice(start + 1);
                renderMask();
                this.setSelectionRange(start, start);
            } else if (start !== end) {
                realValue = realValue.slice(0, start) + realValue.slice(end);
                renderMask();
                this.setSelectionRange(start, start);
            }
        }
    });

    pwdInput.addEventListener('paste', function (e) {
        if (!masked) return;
        e.preventDefault();
        const text = e.clipboardData.getData('text/plain');
        const start = this.selectionStart;
        const end = this.selectionEnd;
        realValue = realValue.slice(0, start) + text + realValue.slice(end);
        renderMask();
        const pos = start + text.length;
        this.setSelectionRange(pos, pos);
    });

    pwdInput.addEventListener('input', function () {
        if (!masked) realValue = this.value;
    });

    pwdInput.addEventListener('copy', function (e) {
        if (masked) e.preventDefault();
    });

    pwdInput.addEventListener('cut', function (e) {
        if (masked) e.preventDefault();
    });

    function toggleMask() {
        masked = !masked;
        if (masked) {
            renderMask();
        } else {
            pwdInput.value = realValue;
        }
        document.getElementById('eye-open').style.display  = masked ? 'block' : 'none';
        document.getElementById('eye-closed').style.display = masked ? 'none'  : 'block';
        pwdInput.focus();
    }

    document.getElementById('sync-form').addEventListener('submit', function () {
        pwdInput.value = realValue;
    });
</script>
